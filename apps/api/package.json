{
  "name": "@riftcoach/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun --env-file=../../.env --watch src/index.ts",
    "start": "bun --env-file=../../.env src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir=dist",
    "lint": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "bun --env-file=../../.env drizzle-kit generate",
    "db:migrate": "bun --env-file=../../.env drizzle-kit migrate",
    "db:studio": "bun --env-file=../../.env drizzle-kit studio",
    "db:check": "bun --env-file=../../.env src/db/check.ts",
    "riot:smoke": "bun --env-file=../../.env src/riot/smoke.ts",
    "refresh:acceptance": "bun --env-file=../../.env src/refresh/acceptance.ts",
    "dashboard:acceptance": "bun --env-file=../../.env src/dashboard/acceptance.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.3.3",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.3.19",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.2"
  }
}
