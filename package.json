{
  "name": "riftcoach",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --check .",
    "db:generate": "turbo db:generate --filter=@riftcoach/api",
    "db:migrate": "turbo db:migrate --filter=@riftcoach/api",
    "db:check": "turbo db:check --filter=@riftcoach/api",
    "riot:smoke": "bun run --cwd apps/api riot:smoke",
    "refresh:acceptance": "bun run --cwd apps/api refresh:acceptance",
    "dashboard:acceptance": "bun run --cwd apps/api dashboard:acceptance"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
